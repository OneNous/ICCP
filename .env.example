# Copy to ``.env`` in the repository root (same directory as ``config/`` and ``src/``).
# ``.env`` is gitignored — do not commit secrets.
#
# After ``pip install -e ".[supabase]"``, run:  iccp supabase-ping

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# Optional (same key as above; some docs call it SERVICE_KEY):
# SUPABASE_SERVICE_KEY=

# Publishable / anon — for read-only clients (not required on-device for service-role sync):
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=

# SUPABASE_PROJECT_REF=your_project_ref
